{
  "name": "@onenomad/przm-voice",
  "version": "1.0.1",
  "mcpName": "io.github.onenomad-llc/przm-voice",
  "description": "przm Voice — adaptive personality MCP server for AI agents. Part of the przm AI reliability suite. Evolving personality from behavioral signals, style adaptations, and soul-file management.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "przm-voice-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "presets",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OneNomad-LLC/przm-voice.git"
  },
  "homepage": "https://github.com/OneNomad-LLC/przm-voice",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "migrate": "node dist/migrations/run.js",
    "smoke": "node dist/tests/smoke.js && node dist/tests/smoke-auth.js",
    "smoke:auth": "node dist/tests/smoke-auth.js",
    "bench": "pnpm run bench:signal-classification && pnpm run bench:style-recall && pnpm run bench:context-budget && pnpm run bench:sycophancy-detection",
    "bench:signal-classification": "pnpm --filter @onenomad/voice-bench-signal-classification run bench",
    "bench:style-recall": "pnpm --filter @onenomad/voice-bench-style-recall run bench",
    "bench:context-budget": "pnpm --filter @onenomad/voice-bench-context-budget run bench",
    "bench:sycophancy-detection": "pnpm --filter @onenomad/voice-bench-sycophancy-detection run bench",
    "smoke:sycophancy": "node dist/tests/sycophancy.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.0"
  }
}
